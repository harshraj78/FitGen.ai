APP_NAME=FitGen AI

# Local demo default:
DATABASE_URL=sqlite:///./fitgen.db

# Production-style PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://fitgen:fitgen@localhost:5432/fitgen_ai

# Default behavior:
# - SQLite auto-creates tables for easy local demos.
# - PostgreSQL does not auto-create tables; use Alembic migrations.
# Set explicitly only when you understand the tradeoff.
# AUTO_CREATE_TABLES=false

# Optional LLM enrichment. Core planner works without this.
# OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
