APP_NAME=FitGen AI
APP_ENV=development

# Local demo default:
DATABASE_URL=sqlite:///./fitgen.db

# Production-style PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://fitgen:fitgen@localhost:5432/fitgen_ai

# Default behavior:
# - SQLite auto-creates tables for easy local demos.
# - PostgreSQL does not auto-create tables; use Alembic migrations.
# Set explicitly only when you understand the tradeoff.
# AUTO_CREATE_TABLES=false

# Comma-separated frontend origins allowed to call the API.
# For Vercel/Render, replace these with your deployed frontend URL(s).
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8010,http://localhost:8010

# Browser session lifetime. Use a shorter value for stricter production posture.
SESSION_TTL_HOURS=168

# Demo seed routes are disabled automatically when APP_ENV=production unless this is true.
# ENABLE_DEMO_ROUTES=false

# Optional LLM enrichment. Core planner works without this.
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-20b

# Provider-ready automations. Keep disabled until WhatsApp/payment provider webhooks are connected.
WHATSAPP_AUTOMATION_ENABLED=false
PAYMENT_LINKS_ENABLED=false
# BOOKING_BASE_URL=https://your-frontend.example.com/book
# PAYMENT_LINK_BASE_URL=https://your-payment-provider.example.com/pay
# FRONTEND_APP_URL=https://your-vercel-app.vercel.app
